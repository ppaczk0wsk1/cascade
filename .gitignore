# ─── Secrets & credentials (NEVER commit) ───────────────────────
.env
.env.*
!.env.example            # keep a safe, value-less template committed
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
*_rsa
*_ed25519
.aws/
credentials
kubeconfig*

# ─── Terraform ──────────────────────────────────────────────────
*.tfstate                # state can contain secrets — never commit
*.tfstate.*
*.tfvars                 # input values (often secrets)
!*.tfvars.example
.terraform/              # provider/plugin downloads
crash.log
crash.*.log
*.tfplan
tfplan
plan.txt                 # from the plan-on-PR workflow
override.tf
override.tf.json
*_override.tf
.terraformrc
terraform.rc
# NOTE: DO commit .terraform.lock.hcl (it pins provider versions) — it is intentionally NOT ignored.

# ─── Python (Cascade app) ───────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
dist/
build/

# ─── App / runtime data ─────────────────────────────────────────
*.db
canvas.db

# ─── Node / tooling ─────────────────────────────────────────────
node_modules/

# ─── Editors & OS ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Logs ───────────────────────────────────────────────────────
*.log